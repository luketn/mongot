{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "search/components/mappings/fields_CDI.json",
  "type": "object",
  "examples": [
    {
      "<field_name>": [
        {
          "type": "field_type"
        }
      ]
    }
  ],
  "patternProperties": {
    "^.*$": {
      "required": ["type"],
      "oneOf": [
        {
          "$ref": "field_CDI.json"
        },
        {
          "type": "array",
          "items": {
            "$ref": "field_CDI.json"
          }
        }
      ]
    }
  },
  "additionalProperties": false
}
